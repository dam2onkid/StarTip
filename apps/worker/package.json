{
  "name": "@startip/worker",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --env-file=.env --import tsx --watch src/main.ts",
    "build": "tsup src/main.ts --format esm --out-dir dist",
    "start": "node --env-file=.env dist/main.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@startip/shared": "workspace:*",
    "@stellar/stellar-sdk": "^16.0.1",
    "@supabase/supabase-js": "^2.108.2",
    "hono": "^4.7.0",
    "@hono/node-server": "^1.14.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^20",
    "tsx": "^4.19.0",
    "tsup": "^8.5.0",
    "typescript": "^5",
    "vitest": "^4.1.9"
  }
}
